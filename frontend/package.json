{
  "name": "terravision-ai-frontend",
  "version": "1.0.0",
  "description": "TerraVision AI — React SPA frontend with Vite",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":     "vite --port 3000 --open",
    "build":   "vite build",
    "preview": "vite preview --port 3000",
    "lint":    "eslint src --ext .js,.jsx --report-unused-disable-directives"
  },
  "dependencies": {
    "react":                 "^18.3.1",
    "react-dom":             "^18.3.1",
    "leaflet":               "^1.9.4",
    "react-leaflet":         "^4.2.1",
    "react-leaflet-cluster": "^2.1.0"
  },
  "devDependencies": {
    "@types/leaflet":        "^1.9.12",
    "@vitejs/plugin-react":  "^6.0.2",
    "eslint":                "^9.0.0",
    "vite":                  "^8.0.16"
  },
  "engines": { "node": ">=18.0.0" }
}
