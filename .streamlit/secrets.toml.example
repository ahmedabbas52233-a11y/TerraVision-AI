# TerraVision AI — Streamlit Secrets Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in your values.
# This file is safe to commit. secrets.toml is git-ignored.
#
# To get a GEE service account:
#   1. Go to https://console.cloud.google.com
#   2. Create a project and enable the "Earth Engine API"
#   3. IAM → Service Accounts → Create → Download JSON key
#   4. Register at https://signup.earthengine.google.com/#!/service_accounts
#   5. Paste the entire JSON content as a single line below
#
# Without this key the app runs in Demo Mode (live satellite data disabled).
# ─────────────────────────────────────────────────────────────────────────────

GCP_SERVICE_ACCOUNT = '{"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key_id":"YOUR_KEY_ID","private_key":"-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END RSA PRIVATE KEY-----\n","client_email":"YOUR_SA@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"YOUR_CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'
