# TerraVision AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Google Earth Engine ───────────────────────────────────────────────────────
# Paste your full service-account JSON as a single line.
# Leave blank to use Application Default Credentials (gcloud auth).
GCP_SERVICE_ACCOUNT_JSON=

# ── API Authentication ────────────────────────────────────────────────────────
# Secret key required in the X-API-Key header for /v1/predict and /v1/crops.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
TERRAVISION_API_KEY=dev-insecure-key

# ── Deployment Environment ────────────────────────────────────────────────────
# "development" → wildcard CORS, verbose logging
# "production"  → CORS restricted to CORS_ORIGINS, structured JSON logs
TERRAVISION_ENV=development

# ── CORS (production only) ────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ORIGINS=https://terravision.ai,https://www.terravision.ai

GROQ_API_KEY=your_groq_key_here
TERRAVISION_API_KEY=dev-insecure-key
TERRAVISION_BASE_URL=http://127.0.0.1:8000